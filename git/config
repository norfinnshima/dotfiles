[core]
	excludesfile = ~/.config/git/ignore
	quotepath = false
[user]
	name = xxxxx
	email = xxxxx@xxxxx
[init]
	defaultBranch = main
[alias]
	st = status
	adl = add --all
	cm = commit -m
	cmu = commit -m 'update'
	df = diff
	br = branch
	ch = checkout
	lg = log --graph
[status]
	showUntrackedFiles = all
[merge]
	conflictStyle = zdiff3
[color]
	ui = auto

[includeIf "gitdir:~/work/**"]
	path = ~/.config/git/config-work
[includeIf "gitdir:~/workspace/xxxxx/**"]
	path = ~/.config/git/config-dev
